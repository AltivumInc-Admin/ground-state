{
  "name": "ground-state-society-landing",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Landing page for The Ground State Society — the private, members-only network for funded quantum founders.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/fetch-issues.mjs && vite build && vite build --ssr src/entry-static.jsx --outDir dist-ssr && node scripts/prerender.mjs",
    "preview": "vite preview",
    "test": "node --test \"backend/checkout/test/*.test.mjs\" \"backend/subscribe/test/*.test.mjs\" \"backend/broadcast/test/*.test.mjs\"",
    "test:fe": "vitest run",
    "test:fe:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.0",
    "@gsap/react": "^2.1.2",
    "@portabletext/react": "^6.2.0",
    "@react-three/fiber": "^9.6.1",
    "gsap": "^3.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1071.0",
    "@aws-sdk/lib-dynamodb": "^3.1071.0",
    "@sanity/client": "^7.23.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
