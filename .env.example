# Copy to .env.local and fill in real values. .env.local is gitignored.

# Intake endpoints (set in the Amplify console for production)
VITE_APPLY_ENDPOINT=
VITE_SIGNAL_ENDPOINT=

# Stripe — publishable key and catalog IDs are safe in the client bundle
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_ROUND_MONTHLY=price_...
VITE_STRIPE_PRICE_ROUND_ANNUAL=price_...
VITE_STRIPE_PAYMENT_LINK_ROUND=https://buy.stripe.com/...

# Checkout-session backend (backend/checkout). Local harness:
#   node --env-file=.env.local backend/checkout/local.mjs
# Production: the gss-stripe-checkout stack's ApiUrl output.
VITE_CHECKOUT_ENDPOINT=

# Stripe secret key — server/tooling only. No VITE_ prefix, ever:
# Vite only exposes VITE_-prefixed vars to the browser, and this one must never ship.
STRIPE_SECRET_KEY=sk_test_...
