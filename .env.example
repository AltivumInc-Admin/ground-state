# Copy to .env.local and fill in real values. .env.local is gitignored.

# Intake endpoints (set in the Amplify console for production)
VITE_APPLY_ENDPOINT=
# The Signal subscribe endpoint — the gss-subscribe stack's ApiUrl output + /subscribe
# e.g. https://api.altivum.ai/subscribe
VITE_SIGNAL_ENDPOINT=

# Stripe — publishable key and catalog IDs are safe in the client bundle
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_PRICE_ROUND_MONTHLY=price_...
VITE_STRIPE_PRICE_ROUND_ANNUAL=price_...
VITE_STRIPE_PAYMENT_LINK_ROUND=https://buy.stripe.com/...

# Checkout-session backend (backend/checkout). Local harness:
#   node --env-file=.env.local backend/checkout/local.mjs
# Production: the gss-stripe-checkout stack's ApiUrl output.
VITE_CHECKOUT_ENDPOINT=

# Stripe secret key — server/tooling only. No VITE_ prefix, ever:
# Vite only exposes VITE_-prefixed vars to the browser, and this one must never ship.
STRIPE_SECRET_KEY=sk_test_...

# Sanity (build-time only — read by scripts/fetch-issues.mjs via Node, NEVER VITE_-prefixed,
# so no Sanity client or token ever ships to the browser). projectId from `sanity manage`.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-06-01
# Only needed if the dataset is PRIVATE. Leave unset for a public dataset.
SANITY_READ_TOKEN=
# Set to 1 ONLY for a local/preview build with no Sanity configured. fetch-issues
# fails the build on a missing SANITY_PROJECT_ID otherwise, so a production deploy
# that lost its creds can't silently delist the newsletter archive. Production
# (Amplify) sets SANITY_PROJECT_ID and must NOT set this flag.
GSS_ALLOW_EMPTY_ISSUES=1
